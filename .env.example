# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: The port to bind the server to (defaults to 3000)
PORT=3000

# MONGODB_URI: MongoDB database connection string.
# If not provided, the application will fallback to a local persistent JSON file-based database for offline capability.
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/aura_db

# JWT_SECRET: Secret key for signing and verifying JSON Web Tokens (JWT) for the secure admin panel.
JWT_SECRET=supersecretjwtsigningkey_change_me_in_production

# EMAIL_USER & EMAIL_PASS: Transporter credentials for email notifications (e.g. Gmail SMTP credentials).
# If not set, notifications are logged to console.
EMAIL_USER=example@gmail.com
EMAIL_PASS=smtp_app_password

# CLIENT_URL: The URL of the client application (defaults to http://localhost:3000 in dev)
CLIENT_URL=http://localhost:3000

# SUPABASE_URL: The URL of your Supabase project (e.g. https://xyz.supabase.co)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# SUPABASE_ANON_KEY: The public/anon key of your Supabase project
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

